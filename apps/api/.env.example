# AMX-ERP-2026 — API Environment Variables
# Copy this to .env and fill in values before running.
# NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Local (Docker Compose):
DATABASE_URL="postgresql://amdox:amdox_dev_password@localhost:5432/amdox_erp"
# Production (AWS RDS):
# DATABASE_URL="postgresql://USER:PASS@your-rds-endpoint.rds.amazonaws.com:5432/amdox_erp?sslmode=require"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://:amdox_redis_password@localhost:6379"

# ── JWT Secrets (change both in production!) ──────────────────────────────────
JWT_ACCESS_SECRET="change-this-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-this-refresh-secret-min-32-chars"

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ── Email (Nodemailer + SendGrid) ─────────────────────────────────────────────
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@amdox.com"

# ── File Storage (AWS S3) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="ap-south-1"
AWS_S3_BUCKET=""

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
